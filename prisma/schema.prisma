generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
    id String @id @default(uuid())
    username String @unique
    role Role
    password String
}

enum Role {
    Admin_1
    Admin_2
    Owner
}

model Kategori {
  id String @id @default(uuid())
  namaKategori String 
  status Status @default(Aktif)
}

enum Status {
  Aktif
  Nonaktif
}